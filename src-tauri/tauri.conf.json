{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AMQPush",
  "mainBinaryName": "AMQPush",
  "version": "1.2.0",
  "identifier": "com.sgryzhin.amqpush",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AMQPush",
        "width": 1080,
        "height": 780,
        "minWidth": 1080,
        "minHeight": 780,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
